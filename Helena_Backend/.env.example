# Salin file ini jadi .env lalu isi nilai aslinya. JANGAN commit file .env!

JWT_SECRET=ganti_dengan_string_acak_yang_panjang_dan_rahasia

# PENTING: dua baris ini HARUS SAMA PERSIS. MYSQL_ROOT_PASSWORD dipakai langsung
# oleh image resmi MySQL untuk inisialisasi password root. DB_PASSWORD dipakai
# oleh kode service Node.js untuk connect ke MySQL.
DB_PASSWORD=ganti_dengan_password_database_yang_kuat
MYSQL_ROOT_PASSWORD=ganti_dengan_password_database_yang_kuat

ADMIN_DEFAULT_PASSWORD=ganti_dengan_password_admin_awal
